

#main
MO A
SH A
KPA=10
KDA=64
KIA=0
LDA=3
ACA=15625
DCA=15625

#LOOP

' Jog A
JGA=8000
BG A

' Wait for switch press (DI1 goes low) deaccelerates 2048 counts , 1.17 inches 
#WAIT1
JP #WAIT1,@IN[1]=1
ST A
AM A


MO A

' Wait for switch press again to continue
#WAIT2
JP #WAIT2,@IN[1]=1

' Re-enable and loop
SH A

JP #LOOP

EN
